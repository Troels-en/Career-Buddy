# Career-Buddy — Supabase + AI provider secrets
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit real secrets.
# Rotate the database password after the hackathon (Supabase → Settings → Database → Reset Password).

# ============================================================
# SUPABASE
# ============================================================
# Get these from Supabase → Project: Career-Buddy → Settings → API
SUPABASE_PROJECT_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGc_REPLACE_ME

# Get this from Supabase → Settings → Database → Connection string → URI
# Looks like: postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Replace [YOUR-PASSWORD] with your real db password.
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Service-role key (Settings → API → service_role).
# OPTIONAL for hackathon. Only needed if you want to run privileged operations.
# DO NOT expose this in frontend code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc_REPLACE_ME_SERVICE_ROLE

# ============================================================
# AI PROVIDERS (optional for hackathon — Mock-Mode works without these)
# ============================================================
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ============================================================
# SCRAPING (Layer 1+, optional)
# ============================================================
# Apify actor token + user id (Phase F: LinkedIn / AngelList / X).
# Phases A and B do NOT need this — the 4 ATS providers are unauthenticated.
APIFY_TOKEN=apify_api_REPLACE_ME
APIFY_USER_ID=REPLACE_ME
