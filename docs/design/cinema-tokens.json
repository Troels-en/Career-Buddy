{
  "$schema": "https://schemas.anthropic.com/claude-design/theme/v1.json",
  "name": "Career-Buddy Cinema (Sage)",
  "version": "0.2.0",
  "inspiration": "11x.ai marketing-page composition (cinematic photo + glass-morphism overlays + sticky-scroll hero) re-skinned for Career-Buddy: soft cool sage-green palette, friendly Buddy voice, operator-track focus.",

  "color": {
    "moss":     { "value": "oklch(0.22 0.025 160)", "hex": "#1c2620" },
    "pine":     { "value": "oklch(0.42 0.06 155)",  "hex": "#4a6b58" },
    "sage":     { "value": "oklch(0.74 0.05 152)",  "hex": "#aac4af" },
    "mint":     { "value": "oklch(0.87 0.04 155)",  "hex": "#cee0d2" },
    "mist":     { "value": "oklch(0.95 0.02 155)",  "hex": "#ebf2ec" },
    "cream":    { "value": "oklch(0.975 0.012 150)","hex": "#f3f7f1" },
    "meadow":   { "value": "oklch(0.78 0.12 148)",  "hex": "#93cf83" },
    "ink":      { "value": "oklch(0.18 0.018 165)", "hex": "#161e1a" },
    "ink-soft": { "value": "oklch(0.36 0.015 165)", "hex": "#4a544f" },
    "ink-mute": { "value": "oklch(0.55 0.012 165)", "hex": "#7b827d" }
  },

  "glass": {
    "mist":        { "rgba": "rgba(238, 244, 234, 0.72)" },
    "sage":        { "rgba": "rgba(190, 213, 195, 0.58)" },
    "dark":        { "rgba": "rgba(28, 38, 30, 0.62)" },
    "strokeLight": { "rgba": "rgba(255, 255, 255, 0.55)" },
    "strokeDark":  { "rgba": "rgba(0, 0, 0, 0.18)" }
  },

  "blur": {
    "soft":  "12px",
    "glass": "20px",
    "heavy": "36px"
  },

  "radius": {
    "glass":   "1.25rem",
    "glassLg": "1.75rem",
    "pill":    "9999px"
  },

  "typography": {
    "fontDisplay": "Inter, SF Pro Display, system-ui, -apple-system, sans-serif",
    "fontBody":    "Inter, SF Pro Text, system-ui, -apple-system, sans-serif",
    "scale": {
      "display":  { "size": "clamp(3rem, 6.5vw + 1rem, 7rem)",     "tracking": "-0.03em",  "weight": 700 },
      "h1":       { "size": "clamp(2.25rem, 3.5vw + 1rem, 4rem)",  "tracking": "-0.02em",  "weight": 700 },
      "h2":       { "size": "clamp(1.75rem, 1.6vw + 1rem, 2.5rem)","tracking": "-0.015em", "weight": 600 },
      "eyebrow":  { "size": "1rem", "tracking": "0.18em",   "weight": 500, "uppercase": true },
      "body":     { "size": "1.0625rem", "lineHeight": 1.55,   "weight": 400 },
      "caption":  { "size": "1rem",   "tracking": "0.005em","weight": 400 }
    }
  },

  "spacing": {
    "section": {
      "hero":     { "padding": "clamp(96px, 12vh, 160px) clamp(24px, 5vw, 96px)", "minHeight": "88vh" },
      "default":  "clamp(96px, 14vw, 160px) clamp(24px, 5vw, 96px)",
      "tight":    "64px clamp(24px, 5vw, 96px)"
    }
  },

  "rules": {
    "noDropShadowOnGlass":      true,
    "maxAccentsPerPage":        1,
    "noGradientBackgrounds":    true,
    "noEmojiInChrome":          true,
    "minBodyFontPx":            16,
    "minHeadlineWeight":        600,
    "respectReducedMotion":     true,
    "requireBackdropFallback":  true,
    "minPillTapTargetPx":       44
  }
}
